#!/bin/bash
# Apply current theme to all downstream configs via elvish
set -euo pipefail

eval "$({{ .brew_prefix }}/bin/brew shellenv)"

if ! command -v elvish &>/dev/null; then
    echo "elvish not installed yet, skipping theme apply"
    exit 0
fi

# Sync palette database first (needed for both fresh and existing)
echo "Syncing theme palette database..."
elvish -c "use dotfiles/palette; palette:sync"

# Apply current theme, or default to standard-light on fresh install
CURRENT_THEME_FILE="$HOME/.config/dotfiles/current-theme"
if [ ! -f "$CURRENT_THEME_FILE" ]; then
    echo "No theme set, defaulting to standard-light"
    THEME="standard-light"
else
    THEME=$(cat "$CURRENT_THEME_FILE" | tr -d '[:space:]')
fi

echo "Applying theme: $THEME"
elvish -c "use dotfiles/theme; theme:apply $THEME"
