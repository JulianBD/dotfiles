#!/bin/bash
# local_tools hash: {{ include ".chezmoidata/local_tools.toml" | sha256sum }}
set -euo pipefail

eval "$({{ .brew_prefix }}/bin/brew shellenv)"
eval "$(mise activate bash)"

# Bootstrap Haskell toolchain via ghcup (recommended versions)
# ghci is bundled with ghc, not a separate component
ghcup install ghc
ghcup install cabal
ghcup install stack
ghcup install hls

export PATH="$HOME/.ghcup/bin:$HOME/.cabal/bin:$PATH"
export INSTALLDIR="$HOME/.local/bin"

mkdir -p "$INSTALLDIR"

{{ if hasKey . "source_builds" -}}
# ── Source builds ──
{{ range $name, $tool := .source_builds }}
(
  echo "── Building {{ $name }} ──"
  {{ if $tool.needs -}}
  {{ range $tool.needs -}}
  if ! command -v {{ . }} &>/dev/null; then
      echo "  SKIP: {{ $name }} requires {{ . }} but it's not on PATH"
      exit 0
  fi
  {{ end -}}
  {{ end -}}
  WORKDIR=$(mktemp -d)
  trap 'rm -rf "$WORKDIR"' EXIT
  git clone {{ $tool.repo | quote }} "$WORKDIR"
  cd "$WORKDIR"
  {{ $tool.build }}
  echo "  {{ $name }} installed to $INSTALLDIR"
)
{{ end }}
{{ end -}}

{{ if hasKey . "cloned_repos" -}}
# ── Cloned repos ──
{{ range $name, $tool := .cloned_repos }}
(
  echo "── Cloning {{ $name }} ──"
  DEST="{{ $tool.dest | replace "~" "$HOME" }}"
  if [ -d "$DEST" ]; then
      echo "  {{ $name }} already exists at $DEST"
      exit 0
  fi
  mkdir -p "$(dirname "$DEST")"
  git clone {{ $tool.repo | quote }} "$DEST"
  echo "  {{ $name }} cloned to $DEST"
)
{{ end }}
{{ end -}}

{{ if hasKey . "local_links" -}}
# ── Local symlinks ──
{{ range $name, $tool := .local_links }}
(
  echo "── Linking {{ $name }} ──"
  SOURCE="{{ $tool.source | replace "~" "$HOME" }}"
  DEST="{{ if hasKey $tool "dest" }}{{ $tool.dest | replace "~" "$HOME" }}{{ else }}$HOME/.local/bin{{ end }}"
  if [ ! -f "$SOURCE" ]; then
      echo "  SKIP: {{ $name }} source not found at $SOURCE"
      exit 0
  fi
  mkdir -p "$DEST"
  ln -sf "$SOURCE" "$DEST/{{ $name }}"
  echo "  {{ $name }} linked to $DEST/{{ $name }}"
)
{{ end }}
{{ end -}}

echo "Local tools done."
